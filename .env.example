KODI_URL=http://localhost:8080/jsonrpc
# KODI_USER=
# KODI_PASS=

# Audiobookshelf — get your API token from ABS > Settings > Users > your account
ABS_URL=http://localhost:13378
# Per-user tokens (ABS > Settings > Users > your account > API Token)
ABS_TOKEN_ALEXIS=your_abs_api_token_alexis
ABS_TOKEN_MARION=your_abs_api_token_marion
# Legacy fallback (single-user, used as Alexis token if ABS_TOKEN_ALEXIS is not set)
# ABS_TOKEN=your_abs_api_token_here

# ── Log file paths (host machine paths, mounted into the API container) ──────
# Kodi log — typical locations:
#   Linux native : /home/<user>/.kodi/temp/kodi.log
#   Docker Kodi  : /path/to/kodi-config/temp/kodi.log
KODI_LOG_PATH_HOST=/home/user/.kodi/temp/kodi.log
# Container-internal path (keep this as-is)
KODI_LOG_PATH=/kodi.log

# ABS log — typical location inside the ABS config volume:
#   e.g. /opt/abs/config/logs/abslog-2024-01-15.txt
# Tip: use a symlink or set to the latest log file
ABS_LOG_PATH_HOST=/opt/abs/config/logs
ABS_LOG_PATH=/abs.log

# ── PlayStation Network ───────────────────────────────────────────────────────
# How to get your NPSSO token (valid ~2 months):
#   1. Log in at https://my.playstation.com in your browser
#   2. Visit: https://ca.account.sony.com/api/v1/ssocookie
#   3. Copy the "npsso" value from the JSON response
# The service exchanges it for access+refresh tokens automatically at startup.
# Refresh tokens are reused until they expire (~60 days), then re-auth uses the NPSSO again.
# Per-user PSN accounts
PSN_NPSSO_ALEXIS=your_npsso_token_alexis
PSN_ONLINE_ID_ALEXIS=YourPsnUsernameAlexis
PSN_NPSSO_MARION=your_npsso_token_marion
PSN_ONLINE_ID_MARION=YourPsnUsernameMarion
# Legacy fallback (used as Alexis if per-user not set)
# PSN_NPSSO=your_npsso_token_here
# PSN_ONLINE_ID=YourPsnUsername

# ── Metrics source (Docker only) ─────────────────────────────────────────────
# Leave empty → /proc fallback (container-level CPU/RAM, good enough for Linux)
# Windows host with windows_exporter : HOST_METRICS_URL=http://host.docker.internal:9182/metrics
# Linux host with node_exporter      : HOST_METRICS_URL=http://host.docker.internal:9100/metrics
# HOST_METRICS_URL=

# ── Sideloadly ────────────────────────────────────────────────────────────────
# Path to the Sideloadly Local AppData folder on the host
# Windows: C:\Users\<user>\AppData\Local\Sideloadly
# SIDELOADLY_LOCAL_PATH_HOST=C:\Users\<user>\AppData\Local\Sideloadly

# ── UrBackup ──────────────────────────────────────────────────────────────────
# URL du serveur UrBackup (local) ou http://host.docker.internal:55414 (Docker)
URBACKUP_URL=http://localhost:55414
URBACKUP_USER=admin
URBACKUP_PASS=admin

# ── Jellyfin ──────────────────────────────────────────────────────────────────
# URL du serveur Jellyfin (local) ou http://host.docker.internal:8096 (Docker)
JELLYFIN_URL=http://localhost:8096
JELLYFIN_USER=a
JELLYFIN_PASS=a

# ── Courses (Épicerie) ────────────────────────────────────────────────────────
# Authentification par SESSION COOKIE (pas d'email/mot de passe — contourne Cloudflare et 2FA)
#
# Comment obtenir ton cookie de session :
#   1. Ouvre la page historique dans Chrome/Firefox et connecte-toi normalement
#   2. DevTools (F12) → onglet Network → recharge la page
#   3. Clique sur n'importe quelle requête vers le site → Request Headers
#   4. Copie la valeur complète du champ "Cookie"
#   5. Colle-la dans la variable ci-dessous (tout sur une seule ligne)
#   ⚠ Les sessions durent généralement 2 à 4 semaines. Renouveler si scraping échoue.
#
# Métro & Moi — https://www.metro.ca/mon-compte/historique
METRO_SESSION_COOKIE=your_full_cookie_string_here
# Super C — si compte distinct de Métro (sinon METRO_SESSION_COOKIE est réutilisé)
# SUPERC_SESSION_COOKIE=your_full_cookie_string_here
# Walmart Canada — https://www.walmart.ca/fr/orders
WALMART_SESSION_COOKIE=your_full_cookie_string_here
# Chemin de la base SQLite (optionnel, défaut : nexus-grocery.db dans le répertoire courant)
# GROCERY_DB_PATH=/data/nexus-grocery.db
# Répertoire des sessions Playwright (optionnel, défaut : ./grocery-sessions)
GROCERY_SESSIONS_PATH=./grocery-sessions

# Optional: override the dashboard port (default 80)
# DASHBOARD_PORT=8080
