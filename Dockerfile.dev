# Shared dev image — used by both api and dashboard services in docker-compose.dev.yml
# node_modules is installed here; the workspace source is bind-mounted at runtime.
FROM node:22
WORKDIR /app

COPY package.json package-lock.json ./
RUN npm ci
# Source code is mounted over /app at runtime via docker-compose volumes.
# The anonymous volume declared for /app/node_modules ensures the container's
# node_modules (installed above) takes precedence over whatever is on the host.
